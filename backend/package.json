{
  "name": "moodle-client",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev":   "nodemon src/server.js",
    "start": "node src/server.js",
    "sync":  "node src/scripts/sync.js",
    "db:generate:master": "prisma generate",
    "db:generate:user":   "cross-env PRISMA_TARGET=user prisma generate",
    "db:generate":        "npm run db:generate:master && npm run db:generate:user",
    "db:migrate:master":  "prisma migrate dev",
    "db:migrate:user":    "cross-env PRISMA_TARGET=user prisma migrate dev",
    "db:push:master":     "prisma db push",
    "db:push:user":       "cross-env PRISMA_TARGET=user prisma db push",
    "db:studio": "prisma studio",
    "db:setup":           "npm run db:migrate:master && npm run db:generate:master && npm run db:migrate:user && npm run db:generate:user"
  },
  "dependencies": {
    "@libsql/client":          "^0.14.0",
    "@prisma/adapter-libsql":  "^7.5.0",
    "@prisma/client":          "^7.5.0",
    "bcrypt":                  "^6.0.0",
    "cors":                    "^2.8.6",
    "dotenv":                  "^17.3.1",
    "express":                 "^5.2.1",
    "jsonwebtoken":            "^9.0.3",
    "uuid":                    "^11.1.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon":   "^3.1.14",
    "prisma":    "^7.5.0"
  }
}