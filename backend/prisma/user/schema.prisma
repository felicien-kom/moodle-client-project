// prisma/user/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
  // Pas d'url ici — la connexion est injectée dynamiquement via l'adapter libsql dans votre code
}

// ─────────────────────────────────────────────────────────────
// ÉNUMÉRATIONS (Adaptées à votre moteur de diagnostic)
// ─────────────────────────────────────────────────────────────

enum SyncStatus {
  SYNCED
  PENDING_PUSH
  CONFLICT
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubmissionState {
  DRAFT
  SUBMITTED
  GRADED
}

// ─────────────────────────────────────────────────────────────
// INFRASTRUCTURE DE SYNCHRONISATION ET AUTH LOCAL
// ─────────────────────────────────────────────────────────────

model LocalUser {
  id                 Int        @id @default(autoincrement())
  email              String     @unique
  username           String     @unique
  name               String
  role               UserRole   @default(STUDENT)
  clientPasswordHash String
  moodleToken        String
  moodleUserId       Int?
  
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // Bloc des 5 champs techniques de synchronisation
  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  syncCursor SyncCursor?
  syncLogs   SyncLog[]
}

model SyncCursor {
  id         Int       @id @default(autoincrement())
  userId     Int       @unique
  lastCursor Int       @default(0)
  updatedAt  DateTime  @updatedAt
  user       LocalUser @relation(fields: [userId], references: [id])
}

model SyncLog {
  id           Int       @id @default(autoincrement())
  userId       Int
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String
  pushed       Int       @default(0)
  pulled       Int       @default(0)
  conflicts    Int       @default(0)
  errorMessage String?
  user         LocalUser @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// CENTRALISATION DES FICHIERS (Métadonnées & Téléchargement différé)
// ─────────────────────────────────────────────────────────────

model LocalFile {
  id          Int     @id @default(autoincrement())
  filename    String
  moodleUrl   String  @unique // URL absolue vers pluginfile.php sur Moodle
  mimeType    String?
  fileSize    Int?    
  localPath   String? // NULL = Fichier non encore téléchargé (icône cloud à afficher)

  // Clés étrangères optionnelles pointant vers l'entité parente
  fileResourceId   Int?
  folderResourceId Int?
  assignmentId     Int?
  submissionId     Int?

  server_id           Int?       @unique // ID unique du fichier ou hash Moodle
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  // Relations
  fileResource   FileResource?         @relation(fields: [fileResourceId], references: [id])
  folderResource FolderResource?       @relation(fields: [folderResourceId], references: [id])
  assignment     Assignment?           @relation(fields: [assignmentId], references: [id])
  submission     AssignmentSubmission? @relation(fields: [submissionId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// CARNET DE NOTES GLOBAL (Gradebook)
// ─────────────────────────────────────────────────────────────

model Grade {
  id           Int     @id @default(autoincrement())
  courseId     Int
  itemName     String  // Nom de l'activité évaluée
  itemType     String  // "assign", "quiz", "course"
  itemInstance Int?    // server_id de l'activité correspondante
  grade        Float?
  maxGrade     Float?  
  percentage   Float?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course Course @relation(fields: [courseId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// STRUCTURE DES COURS (Conteneurs)
// Ordre de PULL logique : Course ──> Section ──> Module
// ─────────────────────────────────────────────────────────────

model CourseEnrollment {
  id               Int      @id @default(autoincrement())
  courseServerId   Int      @unique  
  enrolledAt       DateTime @default(now())
  enrolledOnServer Boolean  @default(true)  
  syncEnabled      Boolean  @default(true)   
}

model Course {
  id           Int     @id @default(autoincrement())
  title        String
  shortName    String?
  summary      String?
  categoryId   Int?
  categoryName String?
  startDate    Int?
  endDate      Int?
  visible      Boolean @default(true)
  imageUrl     String?
  format       String?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  sections    Section[]
  modules     Module[]
  events      CalendarEvent[]
  assignments Assignment[]
  grades      Grade[]
}

model Section {
  id           Int     @id @default(autoincrement())
  courseId     Int
  name         String  
  sectionIndex Int    
  summary      String?
  visible      Boolean @default(true)

  server_id           Int?       @unique  
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course  Course   @relation(fields: [courseId], references: [id])
  modules Module[]
}

model Module {
  id          Int     @id @default(autoincrement())
  courseId    Int
  sectionId   Int?
  name        String
  modType     String  // "assign" | "resource" | "url" | "folder"
  instance    Int?    // server_id de l'instance cible (ex: id de l'Assignment)
  visible     Boolean @default(true)
  sortOrder   Int     @default(0)
  description String? 

  server_id           Int?       @unique // ID unique Moodle du course_module (cmid)
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course   Course    @relation(fields: [courseId], references: [id])
  section  Section?  @relation(fields: [sectionId], references: [id])
  
  fileResources   FileResource[]
  folderResources FolderResource[]
  externalUrls    ExternalUrl[]
  assignments     Assignment[]
}

// ─────────────────────────────────────────────────────────────
// ACTIVITÉS SPÉCIFIQUES (Contenus)
// ─────────────────────────────────────────────────────────────

// Moodle "mod_resource" : Un fichier unique partagé par l'enseignant
model FileResource {
  id          Int     @id @default(autoincrement())
  moduleId    Int?
  name        String
  intro       String? 

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  module Module?     @relation(fields: [moduleId], references: [id])
  files  LocalFile[] // Liste des fichiers associés (généralement 1 fichier + annexes éventuelles)
}

// Moodle "mod_folder" : Un dossier contenant un ensemble de fichiers
model FolderResource {
  id          Int     @id @default(autoincrement())
  moduleId    Int?
  name        String
  intro       String? 

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  module Module?     @relation(fields: [moduleId], references: [id])
  files  LocalFile[] // Tous les fichiers présents dans ce dossier Moodle
}

// Moodle "mod_url" : Un lien web externe
model ExternalUrl {
  id          Int     @id @default(autoincrement())
  moduleId    Int?
  name        String
  externalUrl String  
  description String?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  module Module? @relation(fields: [moduleId], references: [id])
}

// Moodle "mod_assign" : Un devoir
model Assignment {
  id           Int     @id @default(autoincrement())
  courseId     Int
  moduleId     Int?
  name         String
  intro        String?
  dueDate      Int?
  cutoffDate   Int?
  allowedTypes String? // types de fichiers acceptés (ex: ".pdf,.zip")
  maxFileSize  Int?
  maxGrade     Float?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course       Course                 @relation(fields: [courseId], references: [id])
  module       Module?                @relation(fields: [moduleId], references: [id])
  introFiles   LocalFile[]            // Fichiers joints aux consignes (sujet PDF, etc.)
  submissions  AssignmentSubmission[]
}

// Rendu de devoir effectué par l'étudiant (Propriété exclusive CLIENT)
model AssignmentSubmission {
  id             Int             @id @default(autoincrement())
  assignmentId   Int
  submissionText String?
  state          SubmissionState @default(DRAFT)
  grade          Float?
  gradedAt       Int?
  feedback       String?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH) // Initialisé à PENDING_PUSH lors d'une modif locale
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  assignment     Assignment  @relation(fields: [assignmentId], references: [id])
  submittedFiles LocalFile[] // Fichiers déposés par l'étudiant pour ce rendu
}

// ─────────────────────────────────────────────────────────────
// CALENDRIER ET ÉVÉNEMENTS
// ─────────────────────────────────────────────────────────────

model CalendarEvent {
  id           Int     @id @default(autoincrement())
  name         String
  description  String?
  eventType    String  // "user" | "course" | "site" | "group"
  timeStart    Int
  timeDuration Int     @default(0)
  courseId     Int?    // Nullable : un événement peut être global (ex: "site" ou "user")

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course      Course? @relation(fields: [courseId], references: [id])
}