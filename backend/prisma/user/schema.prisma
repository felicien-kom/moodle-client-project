// prisma/user/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
  // Pas d'url ici — Prisma 7, connexion via prisma.config.js
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum SyncStatus {
  SYNCED
  PENDING_PUSH
  CONFLICT
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum AttemptState {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum SubmissionState {
  DRAFT
  SUBMITTED
  GRADED
}

// ─────────────────────────────────────────────────────────────
// AUTH LOCAL
// ─────────────────────────────────────────────────────────────

model LocalUser {
  id                 Int        @id @default(autoincrement())
  email              String     @unique
  username           String     @unique
  name               String
  role               UserRole   @default(STUDENT)
  clientPasswordHash String
  moodleToken        String
  moodleUserId       Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  syncCursor SyncCursor?
  syncLogs   SyncLog[]
}

// ─────────────────────────────────────────────────────────────
// SYNC INFRASTRUCTURE
// ─────────────────────────────────────────────────────────────

model SyncCursor {
  id         Int       @id @default(autoincrement())
  userId     Int       @unique
  lastCursor Int       @default(0)
  updatedAt  DateTime  @updatedAt
  user       LocalUser @relation(fields: [userId], references: [id])
}

model SyncLog {
  id           Int       @id @default(autoincrement())
  userId       Int
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String
  pushed       Int       @default(0)
  pulled       Int       @default(0)
  conflicts    Int       @default(0)
  errorMessage String?
  user         LocalUser @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// INSCRIPTIONS AUX COURS
// Contrôle quels cours sont synchronisés localement.
// Deux origines :
//   - L'utilisateur s'inscrit depuis ce client → POST /api/courses/:id/enroll
//   - L'utilisateur était déjà inscrit sur le serveur → détecté au pull et importé
// ─────────────────────────────────────────────────────────────

model CourseEnrollment {
  id             Int      @id @default(autoincrement())
  courseServerId Int      @unique  // server_id du cours (clé de liaison avec Course)
  enrolledAt     DateTime @default(now())
  enrolledOnServer Boolean @default(true)  // true si inscription confirmée sur Moodle
  syncEnabled    Boolean  @default(true)   // false = ne pas synchroniser ce cours
}

// ─────────────────────────────────────────────────────────────
// COURS
// ─────────────────────────────────────────────────────────────

model Course {
  id           Int     @id @default(autoincrement())
  title        String
  shortName    String?
  summary      String?
  categoryId   Int?
  categoryName String?
  startDate    Int?
  endDate      Int?
  visible      Boolean @default(true)
  imageUrl     String? // URL de l'image du cours (moodleUrl, pas téléchargée)
  format       String? // "topics" | "weeks" | "social" | ...

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  modules     Module[]
  sections    Section[]
  quizzes     Quiz[]
  assignments Assignment[]
  annotations Annotation[]
  resources   Resource[]
  grades      Grade[]
}


// ─────────────────────────────────────────────────────────────
// SECTION — chapitre/semaine d'un cours
// Dans Moodle : core_course_get_contents retourne sections[]
// Chaque section contient une liste de modules (activités)
// ─────────────────────────────────────────────────────────────

model Section {
  id          Int     @id @default(autoincrement())
  courseId    Int
  name        String  // ex: "Généralités", "Chapitre 1", "Semaine 2"
  sectionIndex Int    // index d'ordre dans le cours (0, 1, 2...)
  summary     String?
  visible     Boolean @default(true)

  server_id           Int?       @unique  // id Moodle de la section
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course  Course   @relation(fields: [courseId], references: [id])
  modules Module[]
}

// ─────────────────────────────────────────────────────────────
// MODULE — section d'un cours (contient les activités)
// ─────────────────────────────────────────────────────────────

model Module {
  id          Int     @id @default(autoincrement())
  courseId    Int
  sectionId   Int?    // FK locale vers Section.id (null si section non encore créée)
  name        String
  modType     String  // "quiz" | "assign" | "resource" | "url" | "page" | "forum" | "label"
  instance    Int?    // server_id de l'activité associée
  visible     Boolean @default(true)
  sortOrder   Int     @default(0)
  description String? // intro du module si disponible

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course   Course    @relation(fields: [courseId], references: [id])
  section  Section?  @relation(fields: [sectionId], references: [id])
  resources Resource[]
}

// ─────────────────────────────────────────────────────────────
// RESSOURCE — fichiers, URLs, pages liés à un cours/module
// Le fichier n'est PAS téléchargé — on stocke l'URL Moodle
// Le téléchargement effectif est une étape ultérieure
// ─────────────────────────────────────────────────────────────

model Resource {
  id        Int     @id @default(autoincrement())
  courseId  Int
  moduleId  Int?
  name      String
  type      String  // "file" | "url" | "page" | "folder"
  moodleUrl String  // URL Moodle (pluginfile.php ou lien externe)
  mimeType  String? // "application/pdf" | "video/mp4" | ...
  fileSize  Int?    // octets (si connu)
  localPath String? // null jusqu'au téléchargement effectif

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course Course  @relation(fields: [courseId], references: [id])
  module Module? @relation(fields: [moduleId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// QUIZ
// ─────────────────────────────────────────────────────────────

model Quiz {
  id          Int     @id @default(autoincrement())
  courseId    Int
  name        String
  intro       String?
  timeLimit   Int?
  maxAttempts Int     @default(0)
  gradeMethod Int     @default(1)
  sumGrades   Float?
  grade       Float?  // note max du quiz dans le cours
  visible     Boolean @default(true)

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course    Course         @relation(fields: [courseId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id           Int     @id @default(autoincrement())
  quizId       Int
  slot         Int
  qtype        String
  name         String? // nom court de la question
  questionText String
  maxMark      Float   @default(1)
  answers      String? // JSON — choix possibles

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  quiz      Quiz         @relation(fields: [quizId], references: [id])
  responses QuizAnswer[]
}

model QuizAttempt {
  id            Int          @id @default(autoincrement())
  quizId        Int
  attemptNumber Int          @default(1)
  state         AttemptState @default(IN_PROGRESS)
  timeStart     Int?
  timeFinish    Int?
  sumGrades     Float?
  gradedAt      Int?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  quiz    Quiz         @relation(fields: [quizId], references: [id])
  answers QuizAnswer[]
}

model QuizAnswer {
  id           Int     @id @default(autoincrement())
  attemptId    Int
  questionId   Int
  responseText String?
  fraction     Float?
  state        String?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id])
  question QuizQuestion @relation(fields: [questionId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// DEVOIR
// ─────────────────────────────────────────────────────────────

model Assignment {
  id           Int     @id @default(autoincrement())
  courseId     Int
  name         String
  intro        String?
  dueDate      Int?
  cutoffDate   Int?
  allowedTypes String?
  maxFileSize  Int?
  visible      Boolean @default(true)
  maxGrade     Float?  // note maximum

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course      Course                 @relation(fields: [courseId], references: [id])
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id             Int             @id @default(autoincrement())
  assignmentId   Int
  submissionText String?
  filePath       String?
  fileName       String?
  state          SubmissionState @default(DRAFT)
  grade          Float?
  gradedAt       Int?
  feedback       String?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  assignment Assignment @relation(fields: [assignmentId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// NOTES — résultats de l'utilisateur dans les cours
// Propriétaire : SERVER (notes attribuées par l'enseignant)
// ─────────────────────────────────────────────────────────────

model Grade {
  id         Int     @id @default(autoincrement())
  courseId   Int
  itemName   String  // nom de l'activité notée
  itemType   String  // "quiz" | "assign" | "course" | ...
  itemInstance Int?  // server_id de l'activité
  grade      Float?  // note obtenue
  maxGrade   Float?  // note maximale
  percentage Float?  // pourcentage calculé

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course Course @relation(fields: [courseId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// ANNOTATION — notes personnelles, CLIENT gagne TOUJOURS
// Jamais synchronisées vers le serveur Moodle
// ─────────────────────────────────────────────────────────────

model Annotation {
  id       Int     @id @default(autoincrement())
  courseId Int?
  content  String
  color    String  @default("#FFFF88")

  local_updated_at DateTime @updatedAt
  createdAt        DateTime @default(now())

  course Course? @relation(fields: [courseId], references: [id])
}
