// prisma/user/schema.prisma
// Base par utilisateur — ex: data/alice_univ_fr.db
// Toutes les données Moodle de cet utilisateur + son auth locale

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
  // Pas d'url ici — Prisma 7 interdit url dans le schéma
  // La connexion est configurée dans prisma.config.js via l'adapter libsql
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

// Statut de synchronisation — présent sur tous les modèles métier
// PENDING_PUSH : modifié localement, pas encore envoyé au serveur
// SYNCED       : en phase avec le serveur
// CONFLICT     : modifié localement ET sur le serveur depuis la dernière sync
enum SyncStatus {
  SYNCED
  PENDING_PUSH
  CONFLICT
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum AttemptState {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum SubmissionState {
  DRAFT
  SUBMITTED
  GRADED
}

enum EventType {
  CATEGORY
  COURSE
  USER
  SITE
}

// ─────────────────────────────────────────────────────────────
// AUTH LOCAL
// Un seul enregistrement dans cette base — l'utilisateur propriétaire
// ─────────────────────────────────────────────────────────────

model LocalUser {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  username            String    @unique
  name                String
  role                UserRole  @default(STUDENT)
  clientPasswordHash  String    // hash bcrypt — vérifié hors ligne
  moodleToken         String    // token Moodle en clair — utilisé dans les headers HTTP
  moodleUserId        Int?      // userid retourné par core_webservice_get_site_info
  // MOODLE_URL et MOODLE_SERVICE sont dans .env — fixes, pas stockés par profil
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Colonnes sync sur le profil — le profil lui-même peut être modifié hors ligne
  server_id           Int?      @unique   // userid Moodle officiel (= moodleUserId une fois synced)
  sync_status         SyncStatus @default(SYNCED)  // SYNCED par défaut — le profil vient du serveur à la création
  server_timemodified Int?
  local_updated_at    DateTime  @updatedAt
  last_synced_at      Int?

  // Relations
  syncCursor  SyncCursor?
  syncLogs    SyncLog[]
}

// ─────────────────────────────────────────────────────────────
// SYNC INFRASTRUCTURE
// ─────────────────────────────────────────────────────────────

model SyncCursor {
  id         Int       @id @default(autoincrement())
  userId     Int       @unique
  lastCursor Int       @default(0)   // Unix timestamp — 0 si jamais synced
  updatedAt  DateTime  @updatedAt
  user       LocalUser @relation(fields: [userId], references: [id])
}

model SyncLog {
  id           Int       @id @default(autoincrement())
  userId       Int
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    // "RUNNING" | "SUCCESS" | "PARTIAL" | "FAILED"
  pushed       Int       @default(0)
  pulled       Int       @default(0)
  conflicts    Int       @default(0)
  errorMessage String?
  user         LocalUser @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// COURS
// Pulled depuis Moodle — lecture seule pour étudiant
// ─────────────────────────────────────────────────────────────

model Course {
  id           Int     @id @default(autoincrement())
  title        String  // fullname Moodle
  shortName    String? // shortname Moodle
  summary      String?
  categoryId   Int?
  categoryName String?
  startDate    Int?    // Unix timestamp
  endDate      Int?    // Unix timestamp
  visible      Boolean @default(true)
  enrolledAt   Int?    // Unix timestamp d'inscription

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  modules     Module[]
  quizzes     Quiz[]
  assignments Assignment[]
  events      Event[]
  annotations Annotation[]
}

// ─────────────────────────────────────────────────────────────
// MODULE — section/activité d'un cours
// ─────────────────────────────────────────────────────────────

model Module {
  id        Int     @id @default(autoincrement())
  courseId  Int
  name      String
  modType   String  // "quiz" | "assign" | "resource" | "url" | "forum" | ...
  instance  Int?    // server_id de l'activité associée (quiz, devoir, etc.)
  visible   Boolean @default(true)
  sortOrder Int     @default(0)

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course Course @relation(fields: [courseId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// QUIZ
// ─────────────────────────────────────────────────────────────

model Quiz {
  id          Int     @id @default(autoincrement())
  courseId    Int
  name        String
  intro       String?
  timeLimit   Int?    // secondes — null = pas de limite
  maxAttempts Int     @default(0)   // 0 = illimité
  gradeMethod Int     @default(1)   // 1=meilleur, 2=moyenne, 3=premier, 4=dernier
  sumGrades   Float?
  visible     Boolean @default(true)

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course    Course         @relation(fields: [courseId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id           Int    @id @default(autoincrement())
  quizId       Int
  slot         Int    // position dans le quiz
  qtype        String // "multichoice" | "truefalse" | "shortanswer" | "essay"
  questionText String
  maxMark      Float  @default(1)
  answers      String? // JSON sérialisé — choix possibles selon le type

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  quiz      Quiz         @relation(fields: [quizId], references: [id])
  responses QuizAnswer[]
}

// ─────────────────────────────────────────────────────────────
// TENTATIVE DE QUIZ — propriété exclusive étudiant (CLIENT gagne)
// ─────────────────────────────────────────────────────────────

model QuizAttempt {
  id            Int          @id @default(autoincrement())
  quizId        Int
  attemptNumber Int          @default(1)
  state         AttemptState @default(IN_PROGRESS)
  timeStart     Int?         // Unix timestamp
  timeFinish    Int?         // Unix timestamp
  sumGrades     Float?
  gradedAt      Int?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  quiz    Quiz         @relation(fields: [quizId], references: [id])
  answers QuizAnswer[]
}

model QuizAnswer {
  id           Int    @id @default(autoincrement())
  attemptId    Int
  questionId   Int
  responseText String? // réponse texte ou ID de choix sérialisé
  fraction     Float?  // score 0..1
  state        String? // "complete" | "incomplete" | "gradedright" | "gradedwrong" | ...

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id])
  question QuizQuestion @relation(fields: [questionId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// DEVOIR (ASSIGNMENT)
// ─────────────────────────────────────────────────────────────

model Assignment {
  id           Int     @id @default(autoincrement())
  courseId     Int
  name         String
  intro        String?
  dueDate      Int?    // Unix timestamp
  cutoffDate   Int?    // Unix timestamp
  allowedTypes String? // "text" | "file" | "both"
  maxFileSize  Int?    // octets
  visible      Boolean @default(true)

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course      Course                 @relation(fields: [courseId], references: [id])
  submissions AssignmentSubmission[]
}

// Soumission de devoir — propriété exclusive étudiant (CLIENT gagne)
model AssignmentSubmission {
  id             Int             @id @default(autoincrement())
  assignmentId   Int
  submissionText String?         // soumission texte en ligne
  filePath       String?         // chemin local vers le fichier
  fileName       String?
  state          SubmissionState @default(DRAFT)
  grade          Float?
  gradedAt       Int?
  feedback       String?

  server_id           Int?       @unique
  sync_status         SyncStatus @default(PENDING_PUSH)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  assignment Assignment @relation(fields: [assignmentId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// ÉVÉNEMENTS
// Pulled depuis Moodle — lecture seule pour étudiant
// ─────────────────────────────────────────────────────────────

model Event {
  id           Int       @id @default(autoincrement())
  name         String
  description  String?
  format       String?   // format de la description (HTML, markdown, etc.)
  categoryId   Int?      // catégorie Moodle associée
  courseId     Int?      // cours associé (null si global)
  groupId      Int?      // groupe associé (null si global)
  userId       Int?      // utilisateur créateur
  eventType    EventType @default(SITE)
  timestart    Int       // Unix timestamp de début
  timeduration Int?      // durée en secondes (null = instantané)
  visible      Boolean   @default(true)
  location     String?   // lieu de l'événement
  timemodified Int?      // Unix timestamp de dernière modification

  server_id           Int?       @unique
  sync_status         SyncStatus @default(SYNCED)
  server_timemodified Int?
  local_updated_at    DateTime   @updatedAt
  last_synced_at      Int?

  course Course? @relation(fields: [courseId], references: [id])
}

// ─────────────────────────────────────────────────────────────
// ANNOTATION — notes personnelles, CLIENT gagne TOUJOURS
// Jamais synchronisées vers le serveur Moodle
// ─────────────────────────────────────────────────────────────

model Annotation {
  id       Int     @id @default(autoincrement())
  courseId Int?    // null = annotation globale
  content  String
  color    String  @default("#FFFF88")

  // Pas de server_id — les annotations restent locales
  local_updated_at DateTime @updatedAt
  createdAt        DateTime @default(now())

  course Course? @relation(fields: [courseId], references: [id])
}
