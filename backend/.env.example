# Environnement
NODE_ENV=development

# Port du serveur client local
CLIENT_PORT=5000

# HOST : mentionner true pour une exposition sur le réseau local
# Sinon, laisser à false
HOST=false

# Dossier où seront stockées les bases SQLite (master.db + [email].db)
DATABASE_DIR=./data

# Auth locale JWT (différent du token Moodle)
JWT_SECRET=change_this_in_production_use_a_long_random_string__77f6f5045e1271e62f212c4d555d45b19564843609c94f48017afd7166c242f3
JWT_EXPIRES_IN=1d

# CORS — origines autorisées pour le frontend (séparées par des virgules)
CORS_ORIGIN=http://localhost,http://127.0.0.1,https://monsite.com

# ──────────────────────────────────────────────────────────────
# MOODLE — configuration de l'instance serveur
# Ces valeurs sont FIXES pour toute l'instance client.
# En cas de changement d'adresse ou de service, modifier ici uniquement.
# ──────────────────────────────────────────────────────────────

# URL de base du serveur Moodle (sans slash final)
MOODLE_URL=http://localhost

# Nom du service Web Services Moodle
# À activer dans Moodle : Administration > Plugins > Web services > External services
MOODLE_SERVICE=moodle
